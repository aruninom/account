<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="partner_ledger_view_form_excel_inherit" model="ir.ui.view">
        <field name="name">partner.ledger.view.form.excel.inherit</field>
        <field name="model">account.report.partner.ledger</field>
        <field name="inherit_id" ref="base_accounting_kit.account_report_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//footer/button[@name='check_report']" position="after">
                <button string="Print Excel" name="action_print_excel" type="object" class="btn btn-primary"/>
            </xpath>
        </field>
    </record>


<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="financial_report_view_form_excel_inherit" model="ir.ui.view">
        <field name="name">financial.report.view.form.excel.inherit</field>
        <field name="model">financial.report</field>
        <field name="inherit_id" ref="base_accounting_kit.financial_report_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//footer/button[@name='view_report_pdf']" position="after">
                <button string="Print Excel" name="action_print_excel" type="object" class="btn btn-primary"/>
            </xpath>
        </field>
    </record>
</odoo>

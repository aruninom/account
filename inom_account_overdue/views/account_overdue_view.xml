<odoo>
    <!-- OVERDUE LIST VIEW (account.move) -->
    <record id="view_account_overdue_tree" model="ir.ui.view">
        <field name="name">account.overdue.tree</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <list string="Due Payment Monitor">
                <field name="invoice_date"/>
                <field name="invoice_date_due"/>
                <field name="journal_id"/>
                <field name="name" string="Entry"/>
                <field name="partner_id"/>
                <field name="move_type"/>
                <field name="amount_total_signed" string="Total"/>
                <field name="amount_residual_signed" string="Pending"/>
                <field name="payment_state"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- DASHBOARD PIVOT VIEW -->
    <record id="view_account_overdue_pivot" model="ir.ui.view">
        <field name="name">account.overdue.pivot</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <pivot string="Overdue Dashboard">
                <field name="partner_id" type="row"/>
                <field name="move_type" type="col"/>
                <field name="amount_residual_signed" type="measure"/>
                <field name="amount_total_signed" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- DASHBOARD GRAPH VIEW -->
    <record id="view_account_overdue_graph" model="ir.ui.view">
        <field name="name">account.overdue.graph</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <graph string="Overdue Dashboard" type="bar">
                <field name="partner_id"/>
                <field name="amount_residual_signed" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- DASHBOARD ACTION -->
    <record id="action_overdue_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">graph,pivot,list,form</field>
        <field name="domain">[
            ('move_type', 'in', ['out_invoice', 'in_invoice']),
            ('state', '=', 'posted'),
            ('invoice_date_due', '&lt;', context_today()),
            ('payment_state', '!=', 'paid')
        ]</field>
        <field name="context">{'search_default_group_partner_id': 1}</field>
    </record>

    <!-- CUSTOMER ACTION -->
    <record id="action_customer_overdue" model="ir.actions.act_window">
        <field name="name">Customer Entries</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_invoice'),
            ('state', '=', 'posted'),
            ('invoice_date_due', '&lt;', context_today()),
            ('payment_state', '!=', 'paid')
        ]</field>
    </record>

    <!-- VENDOR ACTION -->
    <record id="action_vendor_overdue" model="ir.actions.act_window">
        <field name="name">Vendor Entries</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'in_invoice'),
            ('state', '=', 'posted'),
            ('invoice_date_due', '&lt;', context_today()),
            ('payment_state', '!=', 'paid')
        ]</field>
    </record>

    <!-- ROOT MENU -->
    <menuitem id="menu_account_overdue_root"
              name="Due Payment Monitor"
              sequence="10"/>

    <menuitem id="menu_overdue_dashboard"
              name="Dashboard"
              parent="menu_account_overdue_root"
              action="action_overdue_dashboard"
              sequence="1"/>

    <menuitem id="menu_customer_overdue_entries"
              name="Customer Entries"
              parent="menu_account_overdue_root"
              action="action_customer_overdue"
              sequence="2"/>

    <menuitem id="menu_vendor_overdue_entries"
              name="Vendor Entries"
              parent="menu_account_overdue_root"
              action="action_vendor_overdue"
              sequence="3"/>
</odoo>
